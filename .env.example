# Database — use urie_app (non-superuser) so FORCE RLS binds.
# Superuser `urie` is for migrations only: DATABASE_URL_ADMIN
DATABASE_URL=postgresql+asyncpg://urie_app:urie@localhost:5432/urie
DATABASE_URL_ADMIN=postgresql+asyncpg://urie:urie@localhost:5432/urie

# Auth (dev only — replace in production)
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App — use development locally; production on Vercel/hosted deploys
APP_ENV=development

# Vercel: set DATABASE_URL (or connect Vercel Postgres → POSTGRES_URL),
# JWT_SECRET, and APP_ENV=production in Project → Settings → Environment Variables.
LOG_LEVEL=INFO

# Embedding dimension (deterministic mock uses this size)
EMBEDDING_DIM=64

# LLM gateway (default mock = zero-config offline)
LLM_PROVIDER=mock
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_S=45
LLM_MAX_RETRIES=3
LLM_MAX_INTERVIEW_TURNS=8
